# EduPilot — Environment Variables
# Copy this file to .env and fill in your keys.
# Never commit the real .env to version control.

# ── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-groq-api-key-here

# ── Pinecone ─────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key-here

# Pinecone index name (will be created automatically on first run)
PINECONE_INDEX_NAME=edupilot

# GCP is used here — compatible with Streamlit Cloud deployment
# and Pinecone's free-tier starter region
PINECONE_CLOUD=gcp
PINECONE_REGION=us-central1

# ── SQLite ────────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to project root)
SQLITE_DB_PATH=edupilot.db
